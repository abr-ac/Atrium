# Atrium — Docker environment. Copy to `.env`:  cp .env.docker.example .env
#
# Compose auto-loads `.env` for ${VAR} interpolation. Every value here already
# has a working default baked into docker-compose.yml — this file only exists to
# change ports, rotate secrets/keys, or switch the database backend.

# ── Host ports ───────────────────────────────────────────────────────────────
APP_PORT=3401          # the Atrium forum       → http://localhost:3401
ABRA_PORT=4401         # the Abracadabra server → http://abra.localhost:4401

# ── Public backend origin (HOSTED deploys only) ──────────────
# Local `docker compose up` needs nothing here — browser + container share
# `abra.localhost`. For a HOSTED deploy (real domain, HTTPS) the browser is
# remote: give the abracadabra service its OWN public domain (container port
# 3000, TLS) and set it here, or the browser blocks every request as insecure.
# ABRA_PUBLIC_URL=https://abra.example.com

# ── Secrets (CHANGE these for anything beyond local dev) ─────────────────────
ABRA_AUTH_JWT_SECRET=dev-insecure-change-me-atrium-please-rotate
ABRA_ADMIN_USER=owner
ABRA_ADMIN_PASSWORD=owner

# ── RPC v1 service account (the Nitro runner's identity) ─────────────────────
# DEV-ONLY keypair. The PUBLIC key must equal `public_key` in
# docker/abracadabra.toml. Regenerate BOTH for production (see DOCKER.md), then
# update this file AND docker/abracadabra.toml.
ATRIUM_SERVICE_PUBLIC_KEY=xtBLq23ptAfLSZd2rENO3w1QNcT1XjwpBvnZf5hr7BU
ATRIUM_SERVICE_PRIVATE_KEY=PZmu23ZsA4GUwW5S5J7BT9GkOfBlA3IjhDeaUtp9eGY

# ── Forum behaviour ──────────────────────────────────────────────────────────
ATRIUM_REPLY_MODE=flat            # "flat" or "threaded"
# ABRACADABRA_ENTRY_DOC_ID=00000000-0000-0000-0000-000000000000
# ATRIUM_SCHEMA_BUNDLE_DIR=        # left empty in Docker (no sibling schema repo)

# ── Voice mesh TURN relay (optional — for NAT'd peers) ───────────────────────
# ATRIUM_TURN_URL=turn:turn.example.com:3478
# ATRIUM_TURN_USERNAME=
# ATRIUM_TURN_CREDENTIAL=

# ── Database backend ─────────────────────────────────────────────────────────
# Default is SQLite (data persists in the abra-data volume).
# To use Postgres: uncomment ABRA_DATABASE_URL below AND start with
#   docker compose --profile postgres up -d --build
# ABRA_DATABASE_URL=postgres://abra:abra@postgres:5432/abracadabra
# POSTGRES_USER=abra
# POSTGRES_PASSWORD=abra
# POSTGRES_DB=abracadabra
