# Build context exclusions — keep the image lean and the build reproducible.
# `docker/` is kept in context — the server's config.toml is mounted, not copied,
# so excluding it here is harmless, but listing it documents intent.
node_modules
.nuxt
.output
.data
dist
.git
.gitignore
.env
.env.*
*.log
.DS_Store
.vscode
.idea
Dockerfile
.dockerignore
docker-compose*.yml
DOCKER.md
